<!-- =========================
     Lineup Page - This page displays
     The lineup of artists for a 
     specific festival.  This 
     page was newly created to handle
     automatic filling of artists
     based on which festival is
     being viewed.
     ========================= -->

<!-- Including Header -->
<%- include('../../partials/header') %>

<!-- Stylesheets -->
  <link rel="stylesheet" href="/styles/about.css">
  <link rel="stylesheet" href="/styles/lineup.css">

  <!-- Header -->
  <div class="page-header">
    <h1>
      <%= header %>
    </h1>
  </div>

  <!-- Main Content -->
  <main class="main-content lineup page">
    <div class="card-container">
      <form class="artist-card sort-card" method="get" id="sortForm"
        style="display: flex; flex-direction: column; align-items: center; justify-content: center;">
        <div style="font-weight: bold; font-size: 1.8em; margin-bottom: 1em;">Sort Artists</div>
        <label style="display: flex; align-items: center; margin-bottom: 0.5em;">
          <input type="radio" name="sort" value="alpha" <%=sort==='alpha' ? 'checked' : '' %>
          onchange="document.getElementById('sortForm').submit()" style="margin-right: 0.5em;">
          Alphabetical Order
        </label>
        <label style="display: flex; align-items: center;">
          <input type="radio" name="sort" value="festival" <%=sort==='festival' ? 'checked' : '' %>
          onchange="document.getElementById('sortForm').submit()" style="margin-right: 0.5em;">
          Festival Order
        </label>
      </form>

      <!-- Filling in artist data from the JSON -->
      <% artists.forEach(function(artist) { %>
        <a href="<%= artist.link %>" target="_blank" class="artist-card-link">
          <div class="artist-card">
            <img src="<%= artist.image %>" alt="<%= artist.name %>">
            <div class="artist-white-fade"></div>
            <img src="<%= artist.title %>" alt="<%= artist.name %> Title" class="artist-overlay-img">
          </div>
        </a>
        <% }); %>
    </div>

    <!-- Lineup Navigation Buttons
        Can toggle next/previous lineup -->
    <div class="lineup-buttons" style="justify-content: center; margin: 2rem 0;">
      <% const festNumInt=parseInt(festNum); %>
        <% if (festNumInt < maxFestNum) { %>
          <a href="/lineups/fest/<%= festNumInt + 1 %>" class="lineup-btn"> &#8592; AubFest <%= festNumInt + 1 %></a>
          <% } %>
            <a href="/lineup" class="lineup-btn btn-apply">Current Lineup</a>
            <% if (festNumInt > 1) { %>
              <a href="/lineups/fest/<%= festNumInt - 1 %>" class="lineup-btn">AubFest <%= festNumInt - 1 %> &#8594; </a>
              <% } %>
    </div>


  </main>

  <!-- Including Footer -->
  <%- include('../../partials/footer') %>

  <!-- Scripts -->
  <script src="/scripts/lineup.js"></script>