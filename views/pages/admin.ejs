        }
        .admin-logout-btn {
            background: #AE1C33;
            color: #FFFDD0;
        }
        .admin-logout-btn:hover {
            background: #c0392b;
            color: #fff;
            transform: translateY(-6px) scale(1.04) rotate(2deg);
