        <!-- EEK! This looks bad.  Make admin.css ASAP!!!-->
        <style>
        .admin-square-btn {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            width: 260px;
            height: 180px;
            font-size: 2rem;
            font-weight: bold;
            border-radius: 18px;
            box-shadow: 0 2px 12px rgba(0,0,0,0.10);
            text-decoration: none;
            margin-bottom: 0.5rem;
            transition: transform 0.18s, box-shadow 0.18s, background 0.18s, color 0.18s;
            cursor: pointer;
            will-change: transform;
        }
        .admin-square-btn .admin-btn-icon {
            font-size: 2.5rem;
            margin-bottom: 0.5rem;
        }
        .admin-library-btn {
