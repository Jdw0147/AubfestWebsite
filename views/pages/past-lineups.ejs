<!-- =========================
     Past Lineups Page,
     This page displays posters
     from past festivals, once
     clicked, user will be taken
     to a lineup page for that festival
     ========================= -->
<!-- filepath: views/pages/past-lineups.ejs -->

<!-- Including Header -->
<%- include('../partials/header') %>

<!-- Stylesheets-->
<link rel="stylesheet" href="/styles/lineup.css">
<link rel="stylesheet" href="/styles/past-lineups.css">

<!-- Header -->
<div class="page-header">
    <h1>Past Lineups</h1>
</div>

<!-- Main Content -->
<div class="past-lineups-gallery">
  <a href="/lineups/fest/7">
    <img src="/images/flyers/fest7-flyer.jpg" alt="AubFest VII Poster" class="poster-btn">
  </a>
  <a href="/lineups/fest/6">
    <img src="/images/flyers/fest6-flyer.png" alt="AubFest VI Poster" class="poster-btn">
  </a>
  <a href="/lineups/fest/5">
    <img src="/images/flyers/fest5-flyer.jpeg" alt="AubFest V Poster" class="poster-btn">
  </a>
  <a href="/lineups/fest/4">
    <img src="/images/flyers/fest4-flyer.jpeg" alt="AubFest IV Poster" class="poster-btn">
  </a>
  <a href="/lineups/fest/3">
    <img src="/images/flyers/fest3-flyer.jpeg" alt="AubFest III Poster" class="poster-btn">
  </a>
  <a href="/lineups/fest/2">
    <img src="/images/flyers/fest2-flyer.jpeg" alt="AubFest II Poster" class="poster-btn">
  </a>
  <a href="/lineups/fest/1">
